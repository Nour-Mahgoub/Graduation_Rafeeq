        rpy="0 0 0" />
      <mass
        value="0.29095" />
      <inertia
        ixx="0.00088004"
        ixy="7.4539E-20"
        ixz="8.1315E-20"
        iyy="0.00088004"
        iyz="2.6936E-19"
